# Build output
bin/
dist/

# Go
*.test
*.out
coverage.out
coverage.html

# Vendored assets (v0.0.5+ mega-bundle — every binary/image/chart ko
# pack needs, populated by `ko vendor fetch` from scripts/fetch-vendor.sh.
# The vendored assets themselves are NOT committed; only
# vendor-versions.env (version pins) and the fetch script live in git.
# See RUNBOOK §1.2 and SPEC §4.
#
# Layout:
#   third_party/containerd/<ver>/{linux-amd64,linux-arm64}.tar.gz
#   third_party/kubeadm/<ver>/{linux-amd64,linux-arm64}.tar.gz
#   third_party/kubelet/<ver>/{linux-amd64,linux-arm64}.tar.gz
#   third_party/cri-dockerd/<ver>/{linux-amd64,linux-arm64}.tar.gz
#   third_party/registry/<ver>/{linux-amd64,linux-arm64}.tar.gz
#   third_party/docker/{deb,rpm}/{amd64,arm64,x86_64,aarch64}/
#   third_party/images/{k8s,cilium,prometheus}-*.tar
#   third_party/charts/{cilium,kube-prometheus-stack}-*.tgz
third_party/
!vendor-versions.env
!scripts/fetch-vendor.sh

# Frontend
web/node_modules/
web/dist/
web/.vite/

# Local
.env
.env.local
*.local
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# SSH / credentials
*.pem
*.key
id_rsa*

# ko runtime data (when running ko init locally for testing)
.kube/
.kubectl-cache/
