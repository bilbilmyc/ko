# ko vendored asset versions (v0.0.5+)
#
# Every binary + image + chart ko needs to build the offline bundle lives
# under vendor/. `ko vendor fetch` (or scripts/fetch-vendor.sh directly)
# reads versions from THIS file and populates vendor/ — ko pack build then
# reads from vendor/ with ZERO network calls.
#
# Bump a version here, re-run `ko vendor fetch`, re-run `ko pack build`.
# The bundle tarball embeds the version in its filename so the resulting
# deliverable is fully traceable back to this file.

# Container runtime binaries
CONTAINERD_VERSION=v2.1.0
DOCKER_VERSION=28.0.0

# K8s — keep these in lockstep (kubeadm / kubelet ship at the same k8s release)
KUBE_VERSION=v1.32.0
KUBEAADM_VERSION=v1.32.0
KUBELET_VERSION=v1.32.0

# cri-dockerd — needed for `Runtime=Default=docker` on k8s >= 1.24 (dockershim
# removed). Pin a v0.3.x release for the k8s 1.24-1.30 range.
CRI_DOCKERD_VERSION=v0.3.14

# In-cluster registry static binary (distribution/distribution)
REGISTRY_VERSION=2.8.3

# CNI / observability
CILIUM_VERSION=1.16.1
# kube-prometheus-stack chart version (helm chart for prometheus operator
# + prometheus + alertmanager + node-exporter + grafana).
PROMETHEUS_STACK_VERSION=75.6.1
